# ── Backend (server-side only, never exposed to browser) ─────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here        # server-side reference copy
FRED_API_KEY=your_fred_api_key_here                  # server-side reference copy
ALCHEMY_API_KEY=your_alchemy_api_key_here            # reserved for on-chain expansion
ALTERNATIVE_ME_ENDPOINT=https://api.alternative.me/fng/

# ── Frontend (VITE_ prefix required — these ARE exposed in the browser bundle) ─
VITE_COINGECKO_API_KEY=your_coingecko_demo_api_key_here   # adds x-cg-demo-api-key header
VITE_FRED_API_KEY=your_fred_api_key_here                  # used for live DXY data
VITE_ALTERNATIVE_ME_ENDPOINT=https://api.alternative.me/fng/
